# HTML — always revalidate so users get fresh content, but allow conditional caching
<FilesMatch "\.html?$">
  Header set Cache-Control "no-cache, must-revalidate"
</FilesMatch>

# JS + CSS — frozen in v1.3, cache for 7 days
<FilesMatch "\.(css|js)$">
  Header set Cache-Control "public, max-age=604800"
</FilesMatch>

# Icons + images — rarely change, cache for 30 days
<FilesMatch "\.(ico|png|webp|svg)$">
  Header set Cache-Control "public, max-age=2592000"
</FilesMatch>

# PWA manifest — revalidate like HTML
<FilesMatch "\.json$">
  Header set Cache-Control "no-cache, must-revalidate"
</FilesMatch>